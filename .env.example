# Anjo Scaffold — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# REQUIRED — the app will not start without these
# =============================================================================

# Anthropic Claude API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# HMAC signing secret for session tokens — generate with: openssl rand -hex 32
# Must be at least 32 characters. Rotate to invalidate all existing tokens.
ANJO_SECRET=change-me-to-a-long-random-string-minimum-32-chars

# Admin panel key — used to access /admin and /api/admin/* endpoints
# Generate with: openssl rand -hex 24
ANJO_ADMIN_SECRET=change-me-to-a-strong-admin-secret

# Your app's public URL (used in emails, CORS, cookie domain)
ANJO_BASE_URL=https://your-domain.com

# =============================================================================
# ENVIRONMENT
# =============================================================================

# Set to "dev" for local development:
#   - Skips HTTPS enforcement
#   - Allows localhost CORS origins
#   - Relaxes startup secret checks
# Leave unset or set to "production" in prod.
ANJO_ENV=dev

# =============================================================================
# OPTIONAL — Email (Resend)
# =============================================================================

# Resend API key for email verification and password reset.
# If absent, email verification is skipped and all new users auto-verify.
# Get from resend.com
RESEND_API_KEY=re_...

# =============================================================================
# OPTIONAL — Extended Thinking
# =============================================================================

# Enable extended thinking on Claude Sonnet (respond node only).
# Note: incompatible with prompt caching — disable for cost-sensitive deployments.
# Verify your Anthropic/Bedrock plan supports extended thinking before enabling.
ANJO_THINKING_ENABLED=false
ANJO_THINKING_BUDGET=3000

# =============================================================================
# OPTIONAL — AWS Bedrock (alternative LLM provider)
# =============================================================================

# If using AWS Bedrock instead of Anthropic's direct API, set these:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# ANTHROPIC_SMALL_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# ANTHROPIC_MEDIUM_MODEL=us.anthropic.claude-sonnet-4-6
